# ArmillaryLab Environment Configuration Example
# Copy this file to .env and modify the values as needed

# Application Settings
SECRET_KEY=your-secret-key-here
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
# Options: sqlite, postgresql
DATABASE_TYPE=sqlite

# SQLite Configuration (default)
# Uses armillarylab.db in the project root unless SQLITE_PATH is set.
# SQLITE_PATH=armillarylab.db

# PostgreSQL Configuration (when DATABASE_TYPE=postgresql)
# Preferred: set DATABASE_URL directly
# DATABASE_URL=postgresql://username:password@localhost:5432/armillarylab
#
# Or set individual components (used when DATABASE_URL is not set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=armillarylab
# DB_USER=armillarylab
# DB_PASSWORD=your-password
# DB_SSL_MODE=prefer

# PostgreSQL Connection Pool Settings
# DB_POOL_SIZE=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600
# DB_MAX_OVERFLOW=20

# SQLite Settings
# SQLITE_WAL_MODE=true
# SQLITE_TIMEOUT=30

# Application Features
# NINA_INTEGRATION=true
# BACKUP_RETENTION_DAYS=30

# Cloud Platform Detection (automatically detected if available)
# HEROKU=true
# RAILWAY=true
# RENDER=true

# Security Settings (for production)
# SECURE_SSL_REDIRECT=true
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_HTTPONLY=true
# SESSION_COOKIE_SAMESITE=strict